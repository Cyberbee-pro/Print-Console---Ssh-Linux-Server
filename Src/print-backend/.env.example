# This is not made by an AI (well, maybe now it is co-authored by one!)
# ==============================================================================
# Print Console Backend Configuration Profile Example
# ==============================================================================

# --- Express Network Service Configuration ---
# The port number on which the backend daemon listens.
# Default: 5000
PORT=5000

# The origin URL of the Frontend client interface for CORS access validation.
# Default: http://localhost:3000
FRONTEND_ORIGIN="http://localhost:3000"
# Fallback (Legacy): Frontend_Origin="http://localhost:3000"


# --- File Upload Storage Config ---
# Enable/disable local server filesystem persistence.
# - Set to true to store files locally (recommended for VM/Bare metal hosting/aws/g cloud(servered host)).
# - Set to false if hosting on serverless environments (keeps uploads in-memory). EG: vercel
# Default: false
useStorage=true


# --- Mode Selection & System Integration Toggles ---
# SELF_HOST: Toggles local printer hardware & dropzone execution.
# - Set to true to isolate commands to the local system.
# SSH_ENABLED: Alternative toggle. If set to false, disables remote SSH.
# Note: Self-hosted local execution is active if (SELF_HOST === "true" || SSH_ENABLED === "false").
# Default: SSH tunneling is active unless configured otherwise.
SELF_HOST=true
SSH_ENABLED=false

# MOCK_PRINT: Enables software-level virtualization of the CUPS printer environment.
# - Set to true to print to mock spoolers (uses `echo` command prints).
# - Set to false to execute authentic hardware/driver spools (uses `lp` command).
# Default: false
MOCK_PRINT=true


# --- Filesystem Path Configurations (Used when useStorage or self-hosting is active) ---
# The root storage folder where "received", "queue", and "printed" archives will be bootstrapped.
# Default: /srv/PrintConsoleStorage
STORAGE_POOL="/srv/PrintConsoleStorage"
# Fallback (Legacy): STORAGE_POOL_PATH="/srv/PrintConsoleStorage"

# The atomic drop zone directory where raw uploaded documents are written before spooling.
# Default: /srv/PrintConsoleStorage/printConsole
DROP_ZONE_PATH="/srv/PrintConsoleStorage/printConsole"


# --- Printer Driver Targets ---
# The target hardware printer identifier configured inside the host OS spooler (e.g. CUPS).
# - Leave blank to use the system default printer.
# Default: (none)
PrinterName="EpsonL380"


# --- Remote SSH Spooler Ingress (Required ONLY if SELF_HOST=false & SSH_ENABLED=true) ---
# Target hostname or IP address of the remote Linux print spooler node.
SSH_HOST="127.0.0.1"
# Fallback (Legacy): serverIp="127.0.0.1"

# Connection port for the remote SSH server.
# Default: 22
SSH_PORT=22
# Fallback (Legacy): serverPort=22

# System username on the remote target host.
SSH_USER="userName"
# Fallback (Legacy): sshUsr="userName"

# SSH Identity private key. Can be:
# 1. Absolute filepath to the private key (e.g., ~/.ssh/id_rsa or /path/to/key)
# 2. Raw PEM encoded private key string (typically enclosed in quotes).
SSH_KEY_PATH="/path/to/identity/key"
# Fallback (Legacy): sshKey="your_ssh_private_key_content"